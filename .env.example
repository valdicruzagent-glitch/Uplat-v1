# Copy to .env.local (do not commit .env.local)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Webhook verification
# Recommended: set the exact Twilio webhook URL here (must match Twilio console config)
TWILIO_INBOUND_WEBHOOK_URL=
# Temporary fallback (use only until signature verification is working everywhere)
TWILIO_INBOUND_SHARED_SECRET=

# Discord
DISCORD_WEBHOOK_URL=
